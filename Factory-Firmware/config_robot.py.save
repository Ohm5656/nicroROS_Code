from launch import LaunchDescription
from launch_ros.actions import Node
from launch.actions import IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
import os
from ament_index_python.packages import get_package_share_directory

def generate_launch_description():
    # 1. ดึง Path ของ Package ต่างๆ
    # เปลี่ยน 'my_robot_slam' เป็นชื่อโฟลเดอร์/package ที่คุณสร้างจริง
    #pkg_name = 'my_robot_slam' 
    #pkg_share = get_package_share_directory(pkg_name)
    
    slam_toolbox_dir = get_package_share_directory('slam_toolbox')
    yahboom_bringup_dir = get_package_share_directory('yahboomcar_bringup')
    
    # 2. ระบุตำแหน่งไฟล์ .rviz ในโฟลเดอร์ config ของ package
    #rviz_config_path = os.path.join(pkg_share, 'config', 'my_slam_config.rviz')
    rviz_config_path = os.path.join('rviz','slam_config.rviz')
    return LaunchDescription([
        # 3. รัน Bringup ของ Yahboom (เชื่อมต่อ Micro-ROS + LiDAR)
        IncludeLaunchDescription(
            PythonLaunchDescriptionSource(
                os.path.join(yahboom_bringup_dir, 'launch', 'yahboomcar_bringup_launch.py')
            )
        ),
        #รัน SLAM Toolbox (พร้อมพารามิเตอร์ที่ถูกต้องสำหรับ Yahboom)

        IncludeLaunchDescription(

            PythonLaunchDescriptionSource(

                os.path.join(slam_toolbox_dir, 'launch', 'online_async_launch.py')

            ),

            launch_arguments={

                'use_sim_time': 'False',

                'base_frame': 'base_link',

                'odom_frame': 'odom',

                'scan_topic': '/scan',

                'resolution': '0.05',# กำหนดความละเอียดเป็น 5cm ต่อพิกเซล

                'map_update_interval': '1.0', 

    		'minimum_travel_distance': '0.05', # หุ่นต้องวิ่งไปมากกว่า 15 cm ถึงจะอัปเดตแผนที่
    		
    		'minimum_travel_heading': '0.08', #หุ่นยนต์ต้องหมุนตัวอย่างน้อยประมาณ 2.8 องศา (0.05 rad) ระบบถึงจะอัปเดตแผนที่

    		'throttle_scans': '1',

    		'max_laser_range':'3.0',
    		'use_scan_matching': 'True',
                'use_scan_barycenter': 'True',
                'do_loop_closing': 'true',
                'loop_search_maximum_distance': '3.0',
                'scan_buffer_size': '5',
                'scan_buffer_maximum_scan_distance': '2.0',
                'correlation_search_space_dimension': '0.5',
                'correlation_search_space_resolution': '0.01'
 
            }.items()

        ),


        # รัน Static TF (สะพานเชื่อมชื่อเฟรม radar_Link -> laser_frame)
        Node(
            package='tf2_ros',
            executable='static_transform_publisher',
            #arguments=['0', '0', '0', '0', '0', '0', 'base_link', 'laser_frame']
            arguments=['-0.0046412', '0' , '0.094079','0','0','0','base_link','laser_frame']
        ),

      

        # เปิด RViz2 พร้อมโหลดไฟล์ Config จากโฟลเดอร์ config
        Node(
            package='rviz2',
            executable='rviz2',
            name='rviz2',
            arguments=['-d', rviz_config_path],
            output='screen'
        )
    ])
ต้องทำไงต่อบ้าง 

ถ้าแก้ไฟล์ launch เป็นแบบนี้แล้ว ยังไม่จบครับ ต้องทำต่ออีกหลายอย่าง โดยเฉพาะ 3 เรื่องหลัก:

    เช็กว่าไฟล์ที่แก้ “ถูก syntax และ path ถูก”

    ถ้าเรียกผ่าน ros2 launch yahboomcar_nav ... ต้อง build ใหม่

    รันแล้วเช็ก log ว่า slam_toolbox รับ parameter ที่ส่งไปจริงไหม

ผมไล่ให้ทีละขั้นเลย
1) ก่อนอื่น มีจุดที่ควรแก้ในไฟล์นี้ก่อน
จุดที่ 1: path ของ RViz ยังไม่ถูก

ตอนนี้คุณเขียนแบบนี้

rviz_config_path = os.path.join('rviz','slam_config.rviz')

อันนี้เป็น relative path เฉยๆ มีโอกาสหาไฟล์ไม่เจอ

ควรเปลี่ยนเป็น path เต็มจาก package เช่น

yahboom_nav_dir = get_package_share_directory('yahboomcar_nav')
rviz_config_path = os.path.join(yahboom_nav_dir, 'rviz', 'slam_config.rviz')

จุดที่ 2: หลาย parameter อาจ ไม่ถูกส่งเข้า slam_toolbox จริง

ไฟล์

online_async_launch.py

ของ slam_toolbox ปกติส่วนมากจะรับ argument หลักๆ เช่นพวก use_sim_time, slam_params_file อะไรแนวนี้
แต่พวกนี้:

'minimum_travel_distance'
'minimum_travel_heading'
'max_laser_range'
'use_scan_matching'
...

ไม่ได้แปลว่าจะส่งเข้าได้ตรงๆ ทุกตัว
ขึ้นอยู่กับว่า launch ของ slam_toolbox ตัวนั้นมี DeclareLaunchArgument() รองรับหรือไม่

สรุปคือ:

    ถ้า launch เดิมของ slam_toolbox ไม่ได้ประกาศ argument นี้ไว้

    ต่อให้ใส่ใน launch_arguments={...} ก็อาจ ไม่เข้า node จริง

วิธีที่ถูกและนิ่งกว่า

ให้ใช้ ไฟล์ parameter .yaml ของ slam_toolbox แล้วส่งผ่าน slam_params_file

อันนี้สำคัญมาก เพราะถ้าคุณอยากปรับพวก minimum_travel_distance, loop closing, scan buffer แบบจริงจัง
ควรไปแก้ใน yaml จะชัวร์กว่า
จุดที่ 3: คอมเมนต์ในไฟล์ตอนนี้บางจุดไม่ตรงค่าจริง

คุณเขียน:

'minimum_travel_distance': '0.05', # หุ่นต้องวิ่งไปมากกว่า 15 cm ถึงจะอัปเดตแผนที่

แต่ 0.05 เมตร = 5 cm ไม่ใช่ 15 cm

และ

'minimum_travel_heading': '0.08', # ประมาณ 2.8 องศา

แต่ 0.08 rad ≈ 4.58 องศา ไม่ใช่ 2.8
2) แนะนำให้แก้ไฟล์ launch ให้เรียบร้อยก่อน

โครงสร้างที่ปลอดภัยกว่า ควรประมาณนี้

from launch import LaunchDescription
from launch_ros.actions import Node
from launch.actions import IncludeLaunchDescription
from launch.launch_description_sources import PythonLaunchDescriptionSource
import os
from ament_index_python.packages import get_package_share_directory

def generate_launch_description():
    slam_toolbox_dir = get_package_share_directory('slam_toolbox')
    yahboom_bringup_dir = get_package_share_directory('yahboomcar_bringup')
    yahboom_nav_dir = get_package_share_directory('yahboomcar_nav')

    rviz_config_path = os.path.join(yahboom_nav_dir, 'rviz', 'slam_config.rviz')
    slam_params_file = os.path.join(yahboom_nav_dir, 'config', 'slam_toolbox_params.yaml')

    return LaunchDescription([
        IncludeLaunchDescription(
            PythonLaunchDescriptionSource(
                os.path.join(yahboom_bringup_dir, 'launch', 'yahboomcar_bringup_launch.py')
            )
        ),

        IncludeLaunchDescription(
            PythonLaunchDescriptionSource(
                os.path.join(slam_toolbox_dir, 'launch', 'online_async_launch.py')
            ),
            launch_arguments={
                'use_sim_time': 'False',
                'slam_params_file': slam_params_file
            }.items()
        ),

        Node(
            package='tf2_ros',
            executable='static_transform_publisher',
            arguments=['-0.0046412', '0', '0.094079', '0', '0', '0', 'base_link', 'laser_frame']
        ),

        Node(
            package='rviz2',
            executable='rviz2',
            name='rviz2',
            arguments=['-d', rviz_config_path],
            output='screen'
        )
    ])

3) แล้วไปสร้างไฟล์ slam_toolbox_params.yaml

เช่นสร้างไว้ที่

/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/config/slam_toolbox_params.yaml

ตัวอย่างประมาณนี้:

slam_toolbox:
  ros__parameters:
    use_sim_time: false

    odom_frame: odom
    map_frame: map
    base_frame: base_link
    scan_topic: /scan

    mode: mapping
    resolution: 0.05
    map_update_interval: 1.0

    minimum_travel_distance: 0.05
    minimum_travel_heading: 0.08

    throttle_scans: 1
    max_laser_range: 3.0

    use_scan_matching: true
    use_scan_barycenter: true
    do_loop_closing: true

    loop_search_maximum_distance: 3.0
    scan_buffer_size: 5
    scan_buffer_maximum_scan_distance: 2.0

    correlation_search_space_dimension: 0.5
    correlation_search_space_resolution: 0.01

แบบนี้จะชัวร์กว่าส่ง parameter กระจายผ่าน launch_arguments
4) หลังแก้แล้ว ต้อง build ไหม
ถ้าคุณรันแบบนี้

ros2 launch yahboomcar_nav map_slam_toolbox_launch.py

ต้อง build ใหม่
เพราะ ROS 2 จะไปใช้ไฟล์ที่ถูก install ไว้ใน install/ ไม่ใช่หยิบจาก src/ ตรงๆ
คำสั่งที่ควรทำ

เข้า workspace ก่อน

cd /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws

แล้ว build เฉพาะ package นี้

colcon build --packages-select yahboomcar_nav

เสร็จแล้ว source

source /opt/ros/humble/setup.bash
source install/setup.bash

5) แล้วรันยังไง

ros2 launch yahboomcar_nav map_slam_toolbox_launch.py

6) ถ้ารันแล้วควรเช็กอะไรบ้าง
เช็กว่า launch ผ่านไหม

ถ้ามี syntax ผิด จะฟ้องทันที
เช็กว่า node ขึ้นครบไหม

ros2 node list

ควรเห็นประมาณนี้

    /slam_toolbox

    /rviz2

    node ของ bringup

    static tf publisher

เช็ก topic scan มากไหม

ros2 topic list | grep scan
ros2 topic echo /scan

ต้องมีข้อมูล LiDAR วิ่งจริง
เช็ก TF ว่าต่อกันครบไหม

ros2 run tf2_tools view_frames

หรือเช็กเร็วๆ

ros2 run tf2_ros tf2_echo base_link laser_frame

ถ้า static tf ถูก จะต้อง echo ได้
7) ถ้าแก้แล้วแต่เหมือนไม่มีผล มีสาเหตุหลักๆ 3 อย่าง
กรณี A: build แล้วแต่ยังใช้ของเก่า

ต้อง source ใหม่ทุก terminal

source /opt/ros/humble/setup.bash
source /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/install/setup.bash

กรณี B: parameter ไม่ได้ถูกใช้จริง

ให้เช็กด้วย

ros2 param list /slam_toolbox

และ

ros2 param get /slam_toolbox minimum_travel_distance
ros2 param get /slam_toolbox minimum_travel_heading

ถ้า get ไม่ได้ แปลว่า parameter นั้นอาจไม่ได้ถูกโหลดเข้า node
กรณี C: RViz config หาไม่เจอ

ถ้า path ผิด RViz จะเปิดแบบ default หรือ error
เพราะงั้นต้องแก้ path ให้เป็น full path ตามที่บอกด้านบน
8) สรุปสั้นๆ ว่าต้องทำต่ออะไร

ทำตามนี้เลย:
ขั้นที่ 1

แก้ launch file ให้ใช้

    yahboom_nav_dir

    rviz_config_path แบบเต็ม

    slam_params_file

ขั้นที่ 2

สร้างไฟล์

config/slam_toolbox_params.yaml

ขั้นที่ 3

build ใหม่

cd /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws
colcon build --packages-select yahboomcar_nav
source /opt/ros/humble/setup.bash
source install/setup.bash

ขั้นที่ 4

รัน

ros2 launch yahboomcar_nav map_slam_toolbox_launch.py

ขั้นที่ 5

เช็ก

ros2 node list
ros2 topic echo /scan
ros2 param list /slam_toolbox

9) ผมแนะนำแบบตรงๆ

ไฟล์ที่คุณแก้ตอนนี้ แนวคิดโอเค แต่ถ้าจะให้ “ใช้ได้จริงและค่ามีผลแน่นอน”
ควรเปลี่ยนไปใช้ yaml params สำหรับ slam_toolbox จะดีที่สุด

เพราะถ้าส่ง parameter ผ่าน launch_arguments ไปยัง online_async_launch.py ตรงๆ หลายตัวมีโอกาส ไม่ถูกอ่าน

ถ้าคุณต้องการ ผมช่วยเขียนให้ครบได้เลย 2 ไฟล์:

    map_slam_toolbox_launch.py เวอร์ชันแก้เสร็จ

    slam_toolbox_params.yaml เวอร์ชันพร้อมใช้กับ Yahboom ของคุณ


from launch import LaunchDescription
from launch_ros.actions import Node

def generate_launch_description():
    return LaunchDescription([
        Node(
            package='slam_toolbox',
            executable='async_slam_toolbox_node',
            name='slam_toolbox',
            output='screen',
            parameters=[{
                'use_sim_time': False,
                'odom_frame': 'odom',
                'map_frame': 'map',
                'base_frame': 'base_footprint',
                'scan_topic': '/scan',

                'resolution': 0.05,
                'map_update_interval': 1.0,
                'transform_publish_period': 0.05,

                'minimum_travel_distance': 0.15,
                'minimum_travel_heading': 0.05,

                'throttle_scans': 1,
                'max_laser_range': 3.0,

                'use_scan_matching': True,
                'use_scan_barycenter': True,
                'do_loop_closing': True,
                'loop_search_maximum_distance': 3.0,

                'scan_buffer_size': 5,
                'scan_buffer_maximum_scan_distance': 2.0,
                'correlation_search_space_dimension': 0.5,
                'correlation_search_space_resolution': 0.01,

                'debug_logging': False
            }]
        ),

        Node(
            package='tf2_ros',
            executable='static_transform_publisher',
            name='base_link_to_base_laser',
            arguments=['-0.0046412', '0', '0.094079', '0', '0', '0', 'base_link', 'laser_frame']
        ),
    ])
อันเก่าเปนงี้คือใช้ได้แต่ตอนหมุนแมพเคลื่อนต้องเปลี่ยนเปนbase lineมั้ย 

ไม่ใช่ว่าเปลี่ยนเป็น base_link แล้วแมพจะหายเคลื่อนทันทีครับ

ประเด็นหลักคือ base_frame ต้องตรงกับ TF tree ของหุ่นจริง
ไม่ใช่เลือกอันไหนก็ได้

ตอนนี้ในไฟล์คุณมีแบบนี้:

'base_frame': 'base_footprint',

แต่ static tf ของคุณเป็น

'base_link', 'laser_frame'

แปลว่า LiDAR ถูกผูกกับ base_link
ดังนั้นต้องเช็กต่อว่าในระบบของคุณมี TF นี้ไหม:

    odom -> base_footprint

    base_footprint -> base_link

    base_link -> laser_frame

ถ้ามีครบ แบบนี้ก็ใช้ base_footprint ได้

แต่ถ้าในหุ่นคุณ ไม่มี base_footprint จริง หรือ node อื่นๆ ใช้ base_link เป็นตัวหลักหมด
การตั้ง base_frame: base_footprint อาจทำให้ SLAM อ้าง frame ไม่ตรง และมีผลให้แมพเพี้ยน/เคลื่อนตอนหมุนได้
สรุปตอบตรงๆ
ควรเปลี่ยนเป็น base_link ไหม?

    ถ้า TF หลักของหุ่นคุณใช้ base_link จริง และไม่มี base_footprint ที่นิ่ง/ถูกต้อง → ควรเปลี่ยนเป็น base_link

    ถ้ามี base_footprint ถูกต้องอยู่แล้ว → ไม่จำเป็นต้องเปลี่ยน

สำหรับเคสของคุณ

จากที่เห็นไฟล์นี้ ผมมองว่า ควรลองเปลี่ยนเป็น base_link ก่อน เพราะ:

    static tf คุณก็อิง base_link

    Yahboom / ROS robot หลายชุดใช้ base_link เป็นแกนหลัก

    ถ้าตั้ง base_footprint แต่ TF ไม่สมบูรณ์ จะเสี่ยงกว่า

ให้ลองแก้เป็น:

'base_frame': 'base_link',

แต่ต้องเข้าใจก่อน

อาการ “หมุนแล้วแมพเคลื่อน” ส่วนใหญ่ ไม่ได้เกิดจากชื่อ base_frame อย่างเดียว
มักเกิดจากหลายอย่างรวมกัน:

    TF ของ LiDAR ไม่ตรงตำแหน่งจริง

    yaw จาก odom/IMU ไม่นิ่ง

    หุ่นหมุนเร็วเกิน

    minimum_travel_heading / minimum_travel_distance ไม่เหมาะ

    scan matching ยังจูนไม่ดี

    เฟรม laser_frame กับตัวหุ่นไม่ตรงจริง

    มีการสั่นของ LiDAR หรือฐานหุ่น

จุดที่ผมเห็นว่าน่าปรับในไฟล์นี้ด้วย

ตอนนี้คุณตั้ง:

'minimum_travel_distance': 0.15,
'minimum_travel_heading': 0.05,

ค่านี้หมายถึง:

    วิ่งอย่างน้อย 15 cm ค่อยอัปเดต

    หมุนประมาณ 2.86 องศาค่อยอัปเดต

ถ้าเป้าหมายคือให้ตอนหมุนแมพนิ่งขึ้น
ค่าพวกนี้มีผลเหมือนกัน โดยเฉพาะตอนหมุน
แนะนำลองแบบนี้

'minimum_travel_distance': 0.05,
'minimum_travel_heading': 0.08,

เหตุผล:

    อัปเดตถี่ขึ้นตอนเคลื่อนที่

    ตอนหมุนจะไม่ไวเกินจน map สั่นจาก noise

    สมดุลกว่าค่าเดิมสำหรับหุ่นเล็ก

เวอร์ชันที่ผมแนะนำให้ลอง

from launch import LaunchDescription
from launch_ros.actions import Node

def generate_launch_description():
    return LaunchDescription([
        Node(
            package='slam_toolbox',
            executable='async_slam_toolbox_node',
            name='slam_toolbox',
            output='screen',
            parameters=[{
                'use_sim_time': False,
                'odom_frame': 'odom',
                'map_frame': 'map',
                'base_frame': 'base_link',
                'scan_topic': '/scan',

                'resolution': 0.05,
                'map_update_interval': 1.0,
                'transform_publish_period': 0.05,

                'minimum_travel_distance': 0.05,
                'minimum_travel_heading': 0.08,

                'throttle_scans': 1,
                'max_laser_range': 3.0,

                'use_scan_matching': True,
                'use_scan_barycenter': True,
                'do_loop_closing': True,
                'loop_search_maximum_distance': 3.0,

                'scan_buffer_size': 5,
                'scan_buffer_maximum_scan_distance': 2.0,
                'correlation_search_space_dimension': 0.5,
                'correlation_search_space_resolution': 0.01,

                'debug_logging': False
            }]
        ),

        Node(
            package='tf2_ros',
            executable='static_transform_publisher',
            name='base_link_to_laser',
            arguments=['-0.0046412', '0', '0.094079', '0', '0', '0', 'base_link', 'laser_frame']
        ),
    ])

สิ่งที่ควรเช็กก่อนตัดสินว่า base_frame ใช่ไหม

รันคำสั่งนี้:

ros2 run tf2_tools view_frames

หรือ

ros2 run tf2_ros tf2_echo odom base_link
ros2 run tf2_ros tf2_echo odom base_footprint
ros2 run tf2_ros tf2_echo base_link laser_frame

ดูผลแบบนี้

    ถ้า odom -> base_link มี

    แต่ odom -> base_footprint ไม่มี หรือแปลกๆ

แปลว่า ควรใช้ base_link
สรุปสุดท้าย

คำตอบคือ:

    ใช่ มีโอกาสควรเปลี่ยนเป็น base_link

    แต่ แมพเคลื่อนตอนหมุนไม่ได้แปลว่า base_frame ผิดอย่างเดียว

    สำหรับไฟล์ที่คุณส่งมา ผมแนะนำให้ลอง:

        เปลี่ยน base_frame เป็น base_link

        ลด minimum_travel_distance เป็น 0.05

        เพิ่ม minimum_travel_heading เป็น 0.08

    แล้วทดสอบใหม่ตอนหมุนช้าๆ

ถ้าคุณต้องการ ผมช่วยดูต่อให้ได้ว่าในระบบคุณควรใช้ base_link หรือ base_footprint แบบชัวร์ๆ โดยดูจาก output ของ view_frames หรือ tf_echo ที่คุณรันมา.

natdanai@natdanai-Cyborg-15-B2RWFKG:~$ ros2 run tf2_tools view_frames
