แต่มีจุดสำคัญ 2 เรื่อง
1) ต้อง build waypoint_nav หลังแก้ run_waypoints.py

เพราะ run_waypoints.py เป็น ROS package executable

cd /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws
colcon build --packages-select waypoint_nav
