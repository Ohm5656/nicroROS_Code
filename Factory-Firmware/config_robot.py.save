Document
#!/usr/bin/env python3

import math
from typing import List, Tuple

import rclpy
from rclpy.node import Node
from geometry_msgs.msg import PoseStamped


def quaternion_to_yaw(z: float, w: float) -> float:
    """
    แปลง quaternion (เฉพาะ z, w ในระบบ 2D) -> yaw (rad)
    """
    return math.atan2(2.0 * w * z, 1.0 - 2.0 * z * z)


class CollectPointsNode(Node):
    def __init__(self):
        super().__init__("collect_points")

        # -------------------------
        # Parameters
        # -------------------------
        self.declare_parameter("goal_topic", "/goal_pose")
        self.goal_topic = (
            self.get_parameter("goal_topic")
            .get_parameter_value()
            .string_value
        )

        # เก็บจุดในรูปแบบ (x, y, yaw)
        self.points: List[Tuple[float, float, float]] = []

        # -------------------------
        # Subscriber
        # -------------------------
        self.subscription = self.create_subscription(
            PoseStamped,
            self.goal_topic,
            self.goal_callback,
            10,
        )

        # -------------------------
        # Logs
        # -------------------------
        self.get_logger().info("=== Collect Points Node Started ===")
        self.get_logger().info(f"Subscribing goal topic: {self.goal_topic}")
        self.get_logger().info("ใน RViz ให้ใช้ 2D Goal Pose เพื่อเก็บจุด")
        self.get_logger().info("ทุกครั้งที่ลาก goal จะเก็บค่า x, y, yaw")
        self.get_logger().info("เสร็จแล้วกด Ctrl+C เพื่อสรุป WAYPOINTS แบบพร้อม copy")

    def goal_callback(self, msg: PoseStamped):
        x = msg.pose.position.x
        y = msg.pose.position.y
        z = msg.pose.orientation.z
        w = msg.pose.orientation.w

        yaw = quaternion_to_yaw(z, w)

        self.points.append((x, y, yaw))
        idx = len(self.points)

        print(f"Point {idx}: ({x:.3f}, {y:.3f}, {yaw:.3f})")

    def print_summary(self):
        print("\n" + "=" * 70)
        print("COPY THIS TO run_waypoints.py")
        print("=" * 70)

        if not self.points:
            print("WAYPOINTS: List[Tuple[float, float, float]] = []")
            print("=" * 70)
            return

        print("WAYPOINTS: List[Tuple[float, float, float]] = [")
        for x, y, yaw in self.points:
            print(f"    ({x:.3f}, {y:.3f}, {yaw:.3f}),")
        print("]")
        print("=" * 70)

    def destroy_and_shutdown(self):
        try:
            self.destroy_node()
        except Exception:
            pass

        try:
            if rclpy.ok():
                rclpy.shutdown()
        except Exception:
            pass


def main(args=None):
    rclpy.init(args=args)
    node = CollectPointsNode()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass

    node.print_summary()
    node.destroy_and_shutdown()


if __name__ == "__main__":
    main()
พี่ครับอันนี้โค้ดcollect_pointd.pyถ้าผมทำให้มันเป็นแบบนี้

import cv2
import yaml
import math

# ================== CONFIG ==================
MAP_YAML = "my_robot_map.yaml"
MAP_IMAGE = "my_robot_map.pgm"
OUTPUT_YAML = "nav_waypoints.yaml"
SCALE = 2  # 🔥 ปรับความใหญ่ของหน้าจอ (2 = 2 เท่า)

# ================== LOAD MAP ==================
with open(MAP_YAML) as f:
    map_data = yaml.safe_load(f)

resolution = map_data["resolution"]
origin_x, origin_y, _ = map_data["origin"]

img = cv2.imread(MAP_IMAGE)
if img is None:
    raise Exception("โหลด map.pgm ไม่ได้")

original = img.copy()
display = cv2.resize(img, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST)

waypoints = []
start_point = None

# ================== FUNCTIONS ==================
def pixel_to_world(x, y):
    # 🔥 scale กลับ
    x = x / SCALE
    y = y / SCALE

    # 🔥 flip Y (สำคัญมาก)
    h = original.shape[0]
    y = h - y

    world_x = x * resolution + origin_x
    world_y = y * resolution + origin_y
    return world_x, world_y


def compute_orientation(x1, y1, x2, y2):
    yaw = math.atan2(y2 - y1, x2 - x1)
    z = math.sin(yaw / 2)
    w = math.cos(yaw / 2)
    return z, w


def save_yaml():
    with open(OUTPUT_YAML, "w") as f:
        yaml.dump({"waypoints": waypoints}, f, sort_keys=False)
    print("[SAVED YAML]")


def redraw():
    global display
    display = cv2.resize(original, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST)

    for wp in waypoints:
        px = int((wp["x"] - origin_x) / resolution)
        py = int((wp["y"] - origin_y) / resolution)
        py = original.shape[0] - py

        px = int(px * SCALE)
        py = int(py * SCALE)

        cv2.circle(display, (px, py), 5, (0, 255, 0), -1)


# ================== MOUSE ==================
def mouse_callback(event, x, y, flags, param):
    global start_point, display

    if event == cv2.EVENT_LBUTTONDOWN:
        start_point = (x, y)

    elif event == cv2.EVENT_MOUSEMOVE and start_point is not None:
        temp = display.copy()
        cv2.arrowedLine(temp, start_point, (x, y), (0, 0, 255), 2)
        cv2.imshow("map", temp)

    elif event == cv2.EVENT_LBUTTONUP:
        end_point = (x, y)

        # วาดลูกศร
        cv2.arrowedLine(display, start_point, end_point, (0, 0, 255), 2)

        # world coord
        wx1, wy1 = pixel_to_world(*start_point)
        wx2, wy2 = pixel_to_world(*end_point)

        z, w = compute_orientation(wx1, wy1, wx2, wy2)

        waypoint = {
            "task": f"waypoint_{len(waypoints)+1}",
            "x": round(wx1, 3),
            "y": round(wy1, 3),
            "orientation": {
                "z": round(z, 5),
                "w": round(w, 5)
            }
        }

        waypoints.append(waypoint)

        print(f"[ADD] {waypoint}")
        save_yaml()

        start_point = None
        redraw()
        cv2.imshow("map", display)


# ================== WINDOW ==================
cv2.namedWindow("map", cv2.WINDOW_NORMAL)
cv2.resizeWindow("map", 1200, 800)

cv2.imshow("map", display)
cv2.setMouseCallback("map", mouse_callback)

print("""
🖱️ วิธีใช้:
- คลิก + ลาก = สร้าง waypoint + ทิศทาง
- กด z = undo
- กด c = clear ทั้งหมด
- กด q = ออก
""")

# ================== LOOP ==================
while True:
    key = cv2.waitKey(1)

    if key == ord('q'):
        break

    elif key == ord('z'):  # undo
        if waypoints:
            waypoints.pop()
            print("[UNDO]")
            redraw()
            cv2.imshow("map", display)

    elif key == ord('c'):  # clear
        waypoints.clear()
        print("[CLEAR ALL]")
        redraw()
        cv2.imshow("map", display)

cv2.destroyAllWindows()
มันสามารถทำได้มั้ยครับ โดยให้ไปเอาแผนที่ในนี้ พอมากส์จุดเสร็จก้ให้มันแสดงจุดไปเก็บไฟล์ๆนึง ที่run_waypointสามารถดึงไฟล์นั้นมา แล้วก้เดินไปยังจุดที่มากส์ โดยเดินเป็นลำดับตามมาสก์
โค้ดที่อัพเป็นไฟล์คือrun_waypoint 

ทำได้ครับ และ เหมาะมาก กับงานของคุณ

แนวคิดคือเปลี่ยนจาก

    เก็บจุดผ่าน RViz /goal_pose

มาเป็น

    เปิดรูปแผนที่ .pgm

    คลิก/ลากบนรูปเพื่อกำหนด ตำแหน่ง + ทิศ

    บันทึกเป็นไฟล์ nav_waypoints.yaml

    ให้ run_waypoints.py อ่านไฟล์นั้น แล้วส่ง waypoint ไปตามลำดับที่มาร์กไว้

แบบนี้ทำได้แน่นอนครับ
ตอนนี้โค้ด run_waypoints.py ของคุณ

ตอนนี้มันยังใช้ WAYPOINTS แบบ hardcode อยู่ และให้เลือกจุดผ่าน input ก่อนส่งไป FollowWaypoints

ดังนั้นถ้าจะเปลี่ยนไปใช้ไฟล์ YAML
ก็แค่แก้ 2 ส่วนหลัก:

    ตัวเก็บจุด → บันทึก YAML

    run_waypoints.py → โหลด YAML แทน WAYPOINTS

สรุปคำตอบตรงๆ
ทำได้ไหม

ได้
ให้เดินตามลำดับที่มาร์กได้ไหม

ได้
ให้ run_waypoints ไปดึงไฟล์นั้นมาได้ไหม

ได้
ดีกว่าเอาค่ามาแปะเองไหม

ดีกว่า เพราะไม่ต้อง copy/paste waypoint เองทุกครั้ง
แนะนำโครงสร้างที่ควรใช้

ผมแนะนำให้เซฟ YAML แบบนี้ จะง่ายสุด

waypoints:
  - task: waypoint_1
    x: 1.020
    y: 0.051
    yaw: 1.547

  - task: waypoint_2
    x: -0.091
    y: 0.478
    yaw: 1.582

ทำไมแนะนำเก็บ yaw

เพราะ run_waypoints.py ของคุณตอนนี้สร้าง PoseStamped จาก (x, y, yaw) อยู่แล้ว
เลยง่ายที่สุด
สิ่งที่ควรปรับในโค้ดเก็บจุดของคุณ

โค้ด OpenCV ที่คุณเขียนมา ทำถูกแนวแล้ว
แต่ตอนนี้มันเซฟ orientation เป็น

"orientation": {
    "z": ...,
    "w": ...
}

ผมแนะนำให้เปลี่ยนเป็นเซฟ yaw ตรงๆ แทน จะง่ายกว่า
เวอร์ชันที่ควรใช้สำหรับ collect_points_map.py

อันนี้เป็นเวอร์ชันที่เหมาะกับงานของคุณมากกว่า:

import cv2
import yaml
import math

MAP_YAML = "my_robot_map.yaml"
MAP_IMAGE = "my_robot_map.pgm"
OUTPUT_YAML = "nav_waypoints.yaml"
SCALE = 2

with open(MAP_YAML, "r") as f:
    map_data = yaml.safe_load(f)

resolution = map_data["resolution"]
origin_x, origin_y, _ = map_data["origin"]

img = cv2.imread(MAP_IMAGE)
if img is None:
    raise Exception("โหลด map.pgm ไม่ได้")

original = img.copy()
display = cv2.resize(img, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST)

waypoints = []
start_point = None


def pixel_to_world(x, y):
    x = x / SCALE
    y = y / SCALE

    h = original.shape[0]
    y = h - y

    world_x = x * resolution + origin_x
    world_y = y * resolution + origin_y
    return world_x, world_y


def compute_yaw(x1, y1, x2, y2):
    return math.atan2(y2 - y1, x2 - x1)


def save_yaml():
    with open(OUTPUT_YAML, "w") as f:
        yaml.dump({"waypoints": waypoints}, f, sort_keys=False, allow_unicode=True)
    print(f"[SAVED] {OUTPUT_YAML}")


def redraw():
    global display
    display = cv2.resize(original, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST)

    for i, wp in enumerate(waypoints, start=1):
        px = int((wp["x"] - origin_x) / resolution)
        py = int((wp["y"] - origin_y) / resolution)
        py = original.shape[0] - py

        px = int(px * SCALE)
        py = int(py * SCALE)

        cv2.circle(display, (px, py), 5, (0, 255, 0), -1)
        cv2.putText(display, str(i), (px + 8, py - 8),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 0, 0), 1)

        yaw = wp["yaw"]
        arrow_len = 25
        end_x = int(px + arrow_len * math.cos(yaw))
        end_y = int(py - arrow_len * math.sin(yaw))
        cv2.arrowedLine(display, (px, py), (end_x, end_y), (0, 0, 255), 2)


def mouse_callback(event, x, y, flags, param):
    global start_point, display

    if event == cv2.EVENT_LBUTTONDOWN:
        start_point = (x, y)

    elif event == cv2.EVENT_MOUSEMOVE and start_point is not None:
        temp = display.copy()
        cv2.arrowedLine(temp, start_point, (x, y), (0, 0, 255), 2)
        cv2.imshow("map", temp)

    elif event == cv2.EVENT_LBUTTONUP and start_point is not None:
        end_point = (x, y)

        wx1, wy1 = pixel_to_world(*start_point)
        wx2, wy2 = pixel_to_world(*end_point)

        yaw = compute_yaw(wx1, wy1, wx2, wy2)

        waypoint = {
            "task": f"waypoint_{len(waypoints) + 1}",
            "x": round(wx1, 3),
            "y": round(wy1, 3),
            "yaw": round(yaw, 3)
        }

        waypoints.append(waypoint)
        print(f"[ADD] {waypoint}")

        save_yaml()
        start_point = None
        redraw()
        cv2.imshow("map", display)


cv2.namedWindow("map", cv2.WINDOW_NORMAL)
cv2.resizeWindow("map", 1200, 800)
cv2.imshow("map", display)
cv2.setMouseCallback("map", mouse_callback)

print("""
วิธีใช้:
- คลิกค้างแล้วลาก = สร้าง waypoint + ทิศทาง
- กด z = undo
- กด c = clear all
- กด q = quit
""")

while True:
    key = cv2.waitKey(1)

    if key == ord("q"):
        break

    elif key == ord("z"):
        if waypoints:
            waypoints.pop()
            print("[UNDO]")
            save_yaml()
            redraw()
            cv2.imshow("map", display)

    elif key == ord("c"):
        waypoints.clear()
        print("[CLEAR ALL]")
        save_yaml()
        redraw()
        cv2.imshow("map", display)

cv2.destroyAllWindows()

ต่อไปต้องแก้ run_waypoints.py

ตอนนี้ของคุณใช้ WAYPOINTS ที่แปะในไฟล์เอง
ผมแนะนำให้เปลี่ยนเป็นโหลดจาก YAML
เวอร์ชัน run_waypoints.py ที่อ่าน nav_waypoints.yaml

อันนี้เป็นแนวที่เหมาะกับคุณ:

#!/usr/bin/env python3

import math
import yaml
from typing import List, Tuple

import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient

from action_msgs.msg import GoalStatus
from geometry_msgs.msg import PoseStamped
from nav2_msgs.action import FollowWaypoints


def yaw_to_quaternion(yaw: float) -> Tuple[float, float]:
    z = math.sin(yaw / 2.0)
    w = math.cos(yaw / 2.0)
    return z, w


class RunWaypointsNode(Node):
    def __init__(self):
        super().__init__("run_waypoints")

        self.declare_parameter("action_name", "/follow_waypoints")
        self.declare_parameter("frame_id", "map")
        self.declare_parameter("waypoints_file", "nav_waypoints.yaml")

        self.action_name = self.get_parameter("action_name").value
        self.frame_id = self.get_parameter("frame_id").value
        self.waypoints_file = self.get_parameter("waypoints_file").value

        self._action_client = ActionClient(
            self,
            FollowWaypoints,
            self.action_name,
        )

        self.selected_waypoints: List[Tuple[float, float, float]] = []

        self.get_logger().info("=== Run Waypoints Node Started ===")
        self.get_logger().info(f"Using action: {self.action_name}")
        self.get_logger().info(f"Using frame_id: {self.frame_id}")
        self.get_logger().info(f"Using waypoints_file: {self.waypoints_file}")

    def load_waypoints_from_yaml(self) -> bool:
        try:
            with open(self.waypoints_file, "r") as f:
                data = yaml.safe_load(f)

            waypoints_raw = data.get("waypoints", [])
            if not waypoints_raw:
                self.get_logger().error("ไม่มี waypoint ในไฟล์ YAML")
                return False

            self.selected_waypoints = []
            for wp in waypoints_raw:
                x = float(wp["x"])
                y = float(wp["y"])
                yaw = float(wp["yaw"])
                self.selected_waypoints.append((x, y, yaw))

            self.get_logger().info(f"โหลด waypoint ได้ {len(self.selected_waypoints)} จุด")
            return True

        except Exception as e:
            self.get_logger().error(f"โหลดไฟล์ YAML ไม่สำเร็จ: {e}")
            return False

    def build_pose(self, x: float, y: float, yaw: float) -> PoseStamped:
        pose = PoseStamped()
        pose.header.frame_id = self.frame_id
        pose.header.stamp = self.get_clock().now().to_msg()

        pose.pose.position.x = x
        pose.pose.position.y = y
        pose.pose.position.z = 0.0

        z, w = yaw_to_quaternion(yaw)
        pose.pose.orientation.x = 0.0
        pose.pose.orientation.y = 0.0
        pose.pose.orientation.z = z
        pose.pose.orientation.w = w

        return pose

    def send_selected_waypoints(self):
        if not self.selected_waypoints:
            self.get_logger().error("ยังไม่มี waypoint")
            return

        poses: List[PoseStamped] = []

        print("\n" + "=" * 60)
        print("WAYPOINTS ที่จะถูกส่งให้หุ่นวิ่ง")
        print("=" * 60)

        for i, (x, y, yaw) in enumerate(self.selected_waypoints, start=1):
            pose = self.build_pose(x, y, yaw)
            poses.append(pose)
            print(f"{i}. x={x:.3f}, y={y:.3f}, yaw={yaw:.3f}")

        print("=" * 60)

        self.get_logger().info(f"รอ action server {self.action_name} ...")

        if not self._action_client.wait_for_server(timeout_sec=10.0):
            self.get_logger().error(f"ไม่พบ action server {self.action_name}")
            rclpy.shutdown()
            return

        goal_msg = FollowWaypoints.Goal()
        goal_msg.poses = poses

        self.get_logger().info(f"ส่ง waypoint ทั้งหมด {len(poses)} จุด")

        send_goal_future = self._action_client.send_goal_async(
            goal_msg,
            feedback_callback=self.feedback_callback,
        )
        send_goal_future.add_done_callback(self.goal_response_callback)

    def feedback_callback(self, feedback_msg):
        current_waypoint = feedback_msg.feedback.current_waypoint
        self.get_logger().info(f"กำลังไป waypoint index: {current_waypoint}")

    def goal_response_callback(self, future):
        goal_handle = future.result()

        if goal_handle is None:
            self.get_logger().error("ส่ง goal ไม่สำเร็จ")
            rclpy.shutdown()
            return

        if not goal_handle.accepted:
            self.get_logger().error("goal ถูก reject")
            rclpy.shutdown()
            return

        self.get_logger().info("goal accepted")

        result_future = goal_handle.get_result_async()
        result_future.add_done_callback(self.result_callback)

    def result_callback(self, future):
        result_wrapper = future.result()

        if result_wrapper is None:
            self.get_logger().error("ไม่ได้ผลลัพธ์จาก action")
            rclpy.shutdown()
            return

        status = result_wrapper.status
        result = result_wrapper.result

        if status == GoalStatus.STATUS_SUCCEEDED:
            missed = list(result.missed_waypoints)
            if missed:
                self.get_logger().warn(f"ไปไม่ครบทุกจุด, missed_waypoints={missed}")
            else:
                self.get_logger().info("สำเร็จ: ไปครบทุก waypoint")
        else:
            self.get_logger().warn(f"action จบด้วย status code: {status}")

        rclpy.shutdown()


def main(args=None):
    rclpy.init(args=args)
    node = RunWaypointsNode()

    try:
        ok = node.load_waypoints_from_yaml()
        if not ok:
            node.destroy_node()
            rclpy.shutdown()
            return

        node.send_selected_waypoints()
        rclpy.spin(node)

    except KeyboardInterrupt:
        print("\nหยุดโปรแกรมด้วยคีย์บอร์ด")

    finally:
        try:
            node.destroy_node()
        except Exception:
            pass
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

วิธีใช้งานจริง
ขั้นที่ 1

เก็บแมพให้เสร็จ แล้วต้องมีไฟล์:

    my_robot_map.yaml

    my_robot_map.pgm

ขั้นที่ 2

รันตัวคลิกแผนที่

python3 collect_points_map.py

มาร์กจุดตามลำดับที่ต้องการให้หุ่นวิ่ง
พอมาร์กเสร็จจะได้ไฟล์:

nav_waypoints.yaml

ขั้นที่ 3

รัน run_waypoints.py

ros2 run waypoint_nav run_waypoints

หรือถ้าจะส่ง path ของไฟล์เข้าไป:

ros2 run waypoint_nav run_waypoints --ros-args -p waypoints_file:=/home/natdanai/path/nav_waypoints.yaml

ข้อดีของวิธีนี้

    ไม่ต้องลาก 2D Goal Pose ใน RViz ทีละจุด

    ไม่ต้อง copy waypoint มาแปะในไฟล์เอง

    ลำดับการวิ่งตรงตามลำดับที่มาร์ก

    เหมาะกับการเตรียมเส้นทางล่วงหน้า

แต่มีข้อควรระวัง
1) ต้องใช้ map yaml/pgm คู่กันให้ตรง

ห้ามเอา .yaml คนละไฟล์กับ .pgm คนละชุด
2) origin และ resolution ต้องถูก

ถ้า map yaml ไม่ตรงกับ pgm
จุดที่คลิกจะเพี้ยน
3) วิธีนี้เป็น “offline marking”

คือมาร์กจากรูป ไม่ได้อิงตำแหน่งสดใน RViz
ดังนั้นถ้าแผนที่ถูกต้อง มันโอเค
แต่ถ้าแผนที่เลื่อนหรือแก้ใหม่ ต้องมาร์กใหม่
สรุป
ทำได้แน่นอน

และเหมาะกับงานคุณมาก

ตอนนี้ run_waypoints.py ของคุณยังใช้ waypoint แบบ hardcode และ input เลือกจุดเอง
ถ้าเปลี่ยนเป็นอ่าน nav_waypoints.yaml จะใช้ง่ายกว่ามาก
คำแนะนำของผม

    ให้ตัวเก็บจุดเซฟ yaw

    ให้ run_waypoints.py โหลด YAML

    ให้หุ่นวิ่งตามลำดับในไฟล์เลย

ถ้าคุณต้องการ ผมช่วยทำให้ครบแบบพร้อมใช้ได้เลย 3 ไฟล์:

    collect_points_map.py

    run_waypoints.py

    ตัวอย่าง nav_waypoints.yaml
    พร้อมบอกด้วยว่าต้องวางไว้ในโฟลเดอร์ไหนของ package คุณครับ


/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.pgm
/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.yaml
แมพต้องมาเอาตรงนี้เสมอ
/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/waypoint_nav/waypoint_nav/run_waypoints.py
/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/waypoint_nav/waypoint_nav/collect_points.py
อันนี้pathทั้สองขอโค้ดแก้ทั้งไฟล์ 

ได้ครับ ด้านล่างคือ โค้ดแก้ทั้งไฟล์ ตาม path ที่คุณกำหนดเลย

แนวทางนี้คือ:

    collect_points.py จะไปอ่านแมพจาก
    /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.pgm
    /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.yaml

    แล้วเซฟ waypoint ไปที่ไฟล์คงที่:
    /home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/waypoint_nav/waypoint_nav/nav_waypoints.yaml

    run_waypoints.py จะอ่าน nav_waypoints.yaml นี้ แล้ววิ่งตามลำดับที่มาร์กไว้

1) ไฟล์ collect_points.py

แทนทั้งไฟล์นี้เลย:

#!/usr/bin/env python3

import cv2
import yaml
import math
import os

# =========================================================
# FIXED PATHS
# =========================================================
MAP_YAML = "/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.yaml"
MAP_IMAGE = "/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/yahboomcar_nav/maps/yahboom_map.pgm"
OUTPUT_YAML = "/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/waypoint_nav/waypoint_nav/nav_waypoints.yaml"

SCALE = 2  # ขยายหน้าต่างให้คลิกง่ายขึ้น

# =========================================================
# LOAD MAP YAML
# =========================================================
if not os.path.exists(MAP_YAML):
    raise FileNotFoundError(f"ไม่พบไฟล์ MAP_YAML: {MAP_YAML}")

if not os.path.exists(MAP_IMAGE):
    raise FileNotFoundError(f"ไม่พบไฟล์ MAP_IMAGE: {MAP_IMAGE}")

with open(MAP_YAML, "r") as f:
    map_data = yaml.safe_load(f)

resolution = map_data["resolution"]
origin_x, origin_y, _ = map_data["origin"]

# =========================================================
# LOAD MAP IMAGE
# =========================================================
img = cv2.imread(MAP_IMAGE)
if img is None:
    raise RuntimeError(f"โหลดไฟล์แมพไม่ได้: {MAP_IMAGE}")

original = img.copy()
display = cv2.resize(
    original, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST
)

waypoints = []
start_point = None


# =========================================================
# HELPER FUNCTIONS
# =========================================================
def pixel_to_world(x, y):
    """
    แปลง pixel บนรูป -> world coordinate
    """
    x = x / SCALE
    y = y / SCALE

    h = original.shape[0]
    y = h - y

    world_x = x * resolution + origin_x
    world_y = y * resolution + origin_y
    return world_x, world_y


def compute_yaw(x1, y1, x2, y2):
    """
    คำนวณ yaw จากจุดเริ่มลาก -> จุดปลายลูกศร
    """
    return math.atan2(y2 - y1, x2 - x1)


def save_yaml():
    data = {"waypoints": waypoints}
    with open(OUTPUT_YAML, "w") as f:
        yaml.dump(data, f, sort_keys=False, allow_unicode=True)
    print(f"[SAVED] {OUTPUT_YAML}")


def redraw():
    global display
    display = cv2.resize(
        original, None, fx=SCALE, fy=SCALE, interpolation=cv2.INTER_NEAREST
    )

    for i, wp in enumerate(waypoints, start=1):
        # world -> pixel
        px = int((wp["x"] - origin_x) / resolution)
        py = int((wp["y"] - origin_y) / resolution)
        py = original.shape[0] - py

        px = int(px * SCALE)
        py = int(py * SCALE)

        # วาดจุด
        cv2.circle(display, (px, py), 5, (0, 255, 0), -1)

        # เขียนเลขลำดับ
        cv2.putText(
            display,
            str(i),
            (px + 8, py - 8),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.5,
            (255, 0, 0),
            1,
            cv2.LINE_AA,
        )

        # วาดลูกศรตาม yaw
        yaw = wp["yaw"]
        arrow_len = 25
        end_x = int(px + arrow_len * math.cos(yaw))
        end_y = int(py - arrow_len * math.sin(yaw))
        cv2.arrowedLine(display, (px, py), (end_x, end_y), (0, 0, 255), 2)


# =========================================================
# MOUSE CALLBACK
# =========================================================
def mouse_callback(event, x, y, flags, param):
    global start_point, display

    if event == cv2.EVENT_LBUTTONDOWN:
        start_point = (x, y)

    elif event == cv2.EVENT_MOUSEMOVE and start_point is not None:
        temp = display.copy()
        cv2.arrowedLine(temp, start_point, (x, y), (0, 0, 255), 2)
        cv2.imshow("map", temp)

    elif event == cv2.EVENT_LBUTTONUP and start_point is not None:
        end_point = (x, y)

        # world coordinate
        wx1, wy1 = pixel_to_world(*start_point)
        wx2, wy2 = pixel_to_world(*end_point)

        yaw = compute_yaw(wx1, wy1, wx2, wy2)

        waypoint = {
            "task": f"waypoint_{len(waypoints) + 1}",
            "x": round(wx1, 3),
            "y": round(wy1, 3),
            "yaw": round(yaw, 3),
        }

        waypoints.append(waypoint)
        print(f"[ADD] {waypoint}")

        save_yaml()
        start_point = None
        redraw()
        cv2.imshow("map", display)


# =========================================================
# MAIN WINDOW
# =========================================================
cv2.namedWindow("map", cv2.WINDOW_NORMAL)
cv2.resizeWindow("map", 1400, 900)
cv2.imshow("map", display)
cv2.setMouseCallback("map", mouse_callback)

print(f"""
==============================
Collect Points From Map
==============================
MAP YAML : {MAP_YAML}
MAP PGM  : {MAP_IMAGE}
SAVE TO  : {OUTPUT_YAML}

วิธีใช้:
- คลิกค้าง + ลาก = สร้าง waypoint + ทิศทาง
- กด z = undo จุดล่าสุด
- กด c = clear ทั้งหมด
- กด q = ออก
==============================
""")

# =========================================================
# LOOP
# =========================================================
while True:
    key = cv2.waitKey(1) & 0xFF

    if key == ord("q"):
        break

    elif key == ord("z"):
        if waypoints:
            removed = waypoints.pop()
            print(f"[UNDO] {removed}")
            save_yaml()
            redraw()
            cv2.imshow("map", display)

    elif key == ord("c"):
        waypoints.clear()
        print("[CLEAR ALL]")
        save_yaml()
        redraw()
        cv2.imshow("map", display)

cv2.destroyAllWindows()

2) ไฟล์ run_waypoints.py

แทนทั้งไฟล์นี้เลย:

#!/usr/bin/env python3

import math
import yaml
import os
from typing import List, Tuple

import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient

from action_msgs.msg import GoalStatus
from geometry_msgs.msg import PoseStamped
from nav2_msgs.action import FollowWaypoints


WAYPOINTS_YAML = "/home/natdanai/ROS_Source_Code/yahboomcar_ws/function_package_without_WiFi_module/yahboomcar_ws/src/waypoint_nav/waypoint_nav/nav_waypoints.yaml"


def yaw_to_quaternion(yaw: float) -> Tuple[float, float]:
    """
    แปลง yaw -> quaternion (z, w)
    """
    z = math.sin(yaw / 2.0)
    w = math.cos(yaw / 2.0)
    return z, w


class RunWaypointsNode(Node):
    def __init__(self):
        super().__init__("run_waypoints")

        self.declare_parameter("action_name", "/follow_waypoints")
        self.declare_parameter("frame_id", "map")
        self.declare_parameter("waypoints_file", WAYPOINTS_YAML)

        self.action_name = self.get_parameter("action_name").value
        self.frame_id = self.get_parameter("frame_id").value
        self.waypoints_file = self.get_parameter("waypoints_file").value

        self._action_client = ActionClient(
            self,
            FollowWaypoints,
            self.action_name,
        )

        self.selected_waypoints: List[Tuple[float, float, float]] = []

        self.get_logger().info("=== Run Waypoints Node Started ===")
        self.get_logger().info(f"Using action: {self.action_name}")
        self.get_logger().info(f"Using frame_id: {self.frame_id}")
        self.get_logger().info(f"Using waypoints_file: {self.waypoints_file}")

    def load_waypoints_from_yaml(self) -> bool:
        if not os.path.exists(self.waypoints_file):
            self.get_logger().error(f"ไม่พบไฟล์ waypoint: {self.waypoints_file}")
            return False

        try:
            with open(self.waypoints_file, "r") as f:
                data = yaml.safe_load(f)

            waypoints_raw = data.get("waypoints", [])
            if not waypoints_raw:
                self.get_logger().error("ไม่มี waypoint ในไฟล์ YAML")
                return False

            self.selected_waypoints = []
            for i, wp in enumerate(waypoints_raw, start=1):
                x = float(wp["x"])
                y = float(wp["y"])
                yaw = float(wp["yaw"])
                self.selected_waypoints.append((x, y, yaw))
                self.get_logger().info(
                    f"Waypoint {i}: x={x:.3f}, y={y:.3f}, yaw={yaw:.3f}"
                )

            self.get_logger().info(
                f"โหลด waypoint ได้ทั้งหมด {len(self.selected_waypoints)} จุด"
            )
            return True

        except Exception as e:
            self.get_logger().error(f"โหลดไฟล์ YAML ไม่สำเร็จ: {e}")
            return False

    def build_pose(self, x: float, y: float, yaw: float) -> PoseStamped:
        pose = PoseStamped()
        pose.header.frame_id = self.frame_id
        pose.header.stamp = self.get_clock().now().to_msg()

        pose.pose.position.x = x
        pose.pose.position.y = y
        pose.pose.position.z = 0.0

        z, w = yaw_to_quaternion(yaw)
        pose.pose.orientation.x = 0.0
        pose.pose.orientation.y = 0.0
        pose.pose.orientation.z = z
        pose.pose.orientation.w = w

        return pose

    def send_selected_waypoints(self):
        if not self.selected_waypoints:
            self.get_logger().error("ยังไม่มี waypoint ให้ส่ง")
            return

        poses: List[PoseStamped] = []

        print("\n" + "=" * 70)
        print("WAYPOINTS ที่จะถูกส่งให้หุ่นวิ่ง")
        print("=" * 70)

        for i, (x, y, yaw) in enumerate(self.selected_waypoints, start=1):
            pose = self.build_pose(x, y, yaw)
            poses.append(pose)
            print(f"{i}. x={x:.3f}, y={y:.3f}, yaw={yaw:.3f}")

        print("=" * 70)

        self.get_logger().info(f"รอ action server {self.action_name} ...")

        if not self._action_client.wait_for_server(timeout_sec=10.0):
            self.get_logger().error(f"ไม่พบ action server {self.action_name}")
            rclpy.shutdown()
            return

        goal_msg = FollowWaypoints.Goal()
        goal_msg.poses = poses

        self.get_logger().info(f"ส่ง waypoint ทั้งหมด {len(poses)} จุด")

        send_goal_future = self._action_client.send_goal_async(
            goal_msg,
            feedback_callback=self.feedback_callback,
        )
        send_goal_future.add_done_callback(self.goal_response_callback)

    def feedback_callback(self, feedback_msg):
        current_waypoint = feedback_msg.feedback.current_waypoint
        self.get_logger().info(f"กำลังไป waypoint index: {current_waypoint}")

    def goal_response_callback(self, future):
        goal_handle = future.result()

        if goal_handle is None:
            self.get_logger().error("ส่ง goal ไม่สำเร็จ")
            rclpy.shutdown()
            return

        if not goal_handle.accepted:
            self.get_logger().error("goal ถูก reject")
            rclpy.shutdown()
            return

        self.get_logger().info("goal accepted")

        result_future = goal_handle.get_result_async()
        result_future.add_done_callback(self.result_callback)

    def result_callback(self, future):
        result_wrapper = future.result()

        if result_wrapper is None:
            self.get_logger().error("ไม่ได้ผลลัพธ์จาก action")
            rclpy.shutdown()
            return

        status = result_wrapper.status
        result = result_wrapper.result

        if status == GoalStatus.STATUS_SUCCEEDED:
            missed = list(result.missed_waypoints)
            if missed:
                self.get_logger().warn(f"ไปไม่ครบทุกจุด, missed_waypoints={missed}")
            else:
                self.get_logger().info("สำเร็จ: ไปครบทุก waypoint")
        else:
            self.get_logger().warn(f"action จบด้วย status code: {status}")

        rclpy.shutdown()


def main(args=None):
    rclpy.init(args=args)
    node = RunWaypointsNode()

    try:
        ok = node.load_waypoints_from_yaml()
        if not ok:
            node.destroy_node()
            rclpy.shutdown()
            return

        node.send_selected_waypoints()
        rclpy.spin(node)

    except KeyboardInterrupt:
        print("\nหยุดโปรแกรมด้วยคีย์บอร์ด")

    finally:
        try:
            node.destroy_node()
        except Exception:
            pass
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

